{
  "config": {
    "step": {
      "user": {
        "data": {
          "host": "[%key:common::config_flow::data::host%]",
          "port": "[%key:common::config_flow::data::port%]",
          "mac": "MAC",
          "pin": "[%key:common::config_flow::data::pin%]"
        }
      },
      "options": {
        "data": {
          "require_code": "Require PIN code"
        }
      },
      "reconfigure": {
        "data": {
          "host": "[%key:common::config_flow::data::host%]",
          "port": "[%key:common::config_flow::data::port%]",
          "pin": "[%key:common::config_flow::data::pin%]",
          "require_code": "Require PIN code"
        }
      }
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    }
  },
  "options": {
    "step": {
      "init": {
        "data": {
          "require_code": "Require PIN code"
        }
      }
    }
  },
  "entity": {
    "binary_sensor": {
      "energy": {
        "name": "Energy"
      },
      "violated": {
        "name": "Violated"
      },
      "stay": {
        "name": "Stay"
      },
      "low_battery": {
        "name": "Low battery"
      }
    },
    "switch": {
      "pgm": {
        "name": "PGM"
      },
      "annulled": {
        "name": "Annulled"
      }
    }
  },
  "issues": {
    "rf_supervision_failure": {
      "title": "RF supervision failure: {zone}",
      "description": "Zone **{zone}** has lost RF communication with the alarm panel. Check if the sensor is powered on and within range."
    },
    "low_battery": {
      "title": "Low battery: {zone}",
      "description": "Zone **{zone}** has a low battery. Replace the battery to maintain proper operation."
    },
    "system_battery_low": {
      "title": "System battery low",
      "description": "The alarm panel battery is low. Replace or charge the battery to ensure the system operates during power outages."
    },
    "burglary": {
      "title": "Burglary alarm: {zone}",
      "description": "Zone **{zone}** triggered a burglary alarm.",
      "fix_flow": {
        "step": {
          "init": {
            "description": "Enter your PIN code to disarm the alarm.",
            "data": {
              "pin": "[%key:common::config_flow::data::pin%]"
            }
          }
        }
      }
    }
  },
  "exceptions": {
    "open_zone": {
      "message": "Cannot arm: one or more zones are open"
    },
    "wrong_password": {
      "message": "Wrong password"
    }
  }
}
